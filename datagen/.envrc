# CCT-CRT Knowledge Base Environment Configuration
# Source this file: source .envrc

# Add libpq (psql) to PATH
export PATH="/opt/homebrew/opt/libpq/bin:$PATH"

# Kafka broker endpoints (for kcat)
export BROKERS="b-1.accctmskcrtcac1.05hf7o.c4.kafka.ca-central-1.amazonaws.com:9092,b-2.accctmskcrtcac1.05hf7o.c4.kafka.ca-central-1.amazonaws.com:9092,b-3.accctmskcrtcac1.05hf7o.c4.kafka.ca-central-1.amazonaws.com:9092"

# AWS profile for this environment
export AWS_PROFILE="ac-cct-crt"
export AWS_REGION="ca-central-1"

# Load RDS credentials from .env (parent dir)
if [ -f "../.env" ]; then
    export RDS_PGSQL_HOST=$(grep RDS_PGSQL_HOST "../.env" | cut -d: -f2- | xargs)
    export RDS_PGSQL_DBNAME=$(grep RDS_PGSQL_DBNAME "../.env" | cut -d: -f2- | xargs)
    export RDS_PGSQL_USER=$(grep RDS_PGSQL_USER "../.env" | cut -d: -f2- | xargs)
    export PGPASSWORD=$(grep RDS_PGSQL_PASSWORD "../.env" | cut -d: -f2- | xargs)
fi

# Convenience aliases
alias kcat-topics="kcat -b \$BROKERS -L | grep 'topic '"
alias psql-trip="psql -h \$RDS_PGSQL_HOST -U \$RDS_PGSQL_USER -d '\$RDS_PGSQL_DBNAME'"
alias warp-status="/Applications/Cloudflare\ WARP.app/Contents/Resources/warp-cli status"

echo "CCT-CRT environment loaded"
echo "  BROKERS set for Kafka"
echo "  AWS_PROFILE=ac-cct-crt"
echo "  Use 'kcat-topics' to list Kafka topics"
echo "  Use 'psql-trip' to connect to trip-tracer DB"
